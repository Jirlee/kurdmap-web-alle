# KurdMap Mobile — Environment Variables
# Copy to .env and adjust as needed

# API URL — Docker (default)
#EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_API_URL=https://gs6xapi.kurdmap.eu
# API URL — Local .NET development
# EXPO_PUBLIC_API_URL=http://localhost:5110

# API URL — Physical device on same network (use your LAN IP)
# EXPO_PUBLIC_API_URL=http://192.168.1.x:8080

# API URL — Production (public API domain). Used automatically by EAS
# "preview" and "production" build profiles (see eas.json).
# EXPO_PUBLIC_API_URL=https://gs6xapi.kurdmap.eu

# Sentry Crash Reporting (optional — leave empty to disable)
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
