{
  "expo": {
    "name": "KurdMap",
    "slug": "kurdmap-mobile",
    "owner": "jirlee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "kurdmap",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#064E3B"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "de.kurdmap.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "KurdMap uses your location to find nearby businesses.",
        "NSLocationAlwaysUsageDescription": "KurdMap uses your location to find nearby businesses."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#064E3B"
      },
      "package": "de.kurdmap.mobile",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-asset",
      "expo-font",
      "expo-updates",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#064E3B"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#10B981"
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "kurdmap",
          "project": "kurdmap-mobile"
        }
      ],
      "expo-build-properties"
    ],
    "updates": {
      "url": "https://u.expo.dev/90b7a526-7f93-4a49-a833-7f741f86e20c",
      "enabled": true,
      "fallbackToCacheTimeout": 3000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "90b7a526-7f93-4a49-a833-7f741f86e20c"
      }
    }
  }
}
