# KurdMap — Caddy Site Config (Importable Snippet)
# Import this from the host's main /etc/caddy/Caddyfile:
#   import /opt/kurdmap/docker/Caddyfile*
#
# This file intentionally avoids global options because this host serves
# multiple websites from one shared Caddy instance.
#
# ── Upstream ports (IMPORTANT on a multi-stack host) ───────
# The reverse_proxy targets below use environment placeholders with safe
# defaults. If this host publishes the containers on NON-default loopback
# ports (because 4000/8080 are already taken by another stack), set these in
# Caddy's environment so the upstreams match — otherwise Caddy returns 503:
#   KURDMAP_FRONTEND_UPSTREAM  (default localhost:4000)  -> FRONTEND_PORT
#   KURDMAP_ADMIN_UPSTREAM     (default localhost:4001)  -> ADMIN_PORT
#   KURDMAP_API_UPSTREAM       (default localhost:8080)  -> API_PORT
# Recommended: systemd drop-in for caddy with an EnvironmentFile. See
# Docs/Production/16-hetzner-podman-deployment-audit.md (section "Caddy ports").

# ── Shared snippets (prefixed to avoid collisions) ─────────
(kurdmap_security_headers) {
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(self), payment=(), usb=(), interest-cohort=()"
		-Server
		-X-Powered-By
	}
}

(kurdmap_compression) {
	encode zstd gzip
}

(kurdmap_csp_web) {
	header {
		# CSP tuned for Angular/SSR and external assets over HTTPS.
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: https:; font-src 'self' data: https:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'unsafe-inline' https:; connect-src 'self' https: wss:; worker-src 'self' blob:; upgrade-insecure-requests"
	}
}

(kurdmap_proxy_headers) {
	# X-Real-IP is not set automatically by Caddy; the others (X-Forwarded-*) are.
	header_up X-Real-IP {remote_host}
}

(kurdmap_noindex) {
	# Keep the admin panel out of every search engine index. Combined with the
	# noindex robots.txt the panel is reachable only by its direct URL.
	header X-Robots-Tag "noindex, nofollow, noarchive, nosnippet, noimageindex"
}

(kurdmap_json_log_frontend) {
	log {
		output file /var/log/caddy/kurdmap-frontend.log {
			roll_size 10mb
			roll_keep 5
		}
		format json
	}
}

(kurdmap_json_log_admin) {
	log {
		output file /var/log/caddy/kurdmap-admin.log {
			roll_size 10mb
			roll_keep 5
		}
		format json
	}
}

(kurdmap_json_log_api) {
	log {
		output file /var/log/caddy/kurdmap-api.log {
			roll_size 10mb
			roll_keep 5
		}
		format json
	}
}

# ── Frontend: kurdmap.eu ────────────────────────────────────
kurdmap.eu, www.kurdmap.eu {
	import kurdmap_security_headers
	import kurdmap_compression
	import kurdmap_csp_web
	import kurdmap_json_log_frontend

	@www host www.kurdmap.eu
	redir @www https://kurdmap.eu{uri} permanent

	reverse_proxy {$KURDMAP_FRONTEND_UPSTREAM:localhost:4000} {
		import kurdmap_proxy_headers
		# Angular SSR blocks health checks where Host resolves to an IP.
		# health_headers forces the Host header so Angular accepts the probe.
		health_uri /
		health_interval 30s
		health_headers {
			Host "kurdmap.eu"
		}
		transport http {
			dial_timeout 5s
			response_header_timeout 30s
		}
	}
}

# ── Admin Panel: gs6x.kurdmap.eu ───────────────────────────
# Served by the admin container (Angular SPA server) via reverse proxy,
# mirroring the frontend. Hardened: never indexed by search engines, so it is
# reachable only by someone who already knows this URL.
gs6x.kurdmap.eu {
	import kurdmap_security_headers
	import kurdmap_compression
	import kurdmap_csp_web
	import kurdmap_noindex
	import kurdmap_json_log_admin

	# Admin API calls are SAME-ORIGIN under /api/* and proxied to the API
	# container. The admin bundle ships no hardcoded API URL and makes no
	# cross-origin requests (no CORS surface; API origin never exposed in JS).
	handle /api/* {
		reverse_proxy {$KURDMAP_API_UPSTREAM:localhost:8080} {
			import kurdmap_proxy_headers
			# ASP.NET HostFiltering accepts "localhost" (see API block below).
			header_up Host "localhost"
			transport http {
				dial_timeout 5s
				response_header_timeout 30s
			}
		}
	}

	# Everything else → the admin SPA server (noindex + SPA fallback).
	handle {
		reverse_proxy {$KURDMAP_ADMIN_UPSTREAM:localhost:4001} {
			import kurdmap_proxy_headers
			health_uri /
			health_interval 30s
			transport http {
				dial_timeout 5s
				response_header_timeout 30s
			}
		}
	}
}

# ── API: gs6xapi.kurdmap.eu ─────────────────────────────────────
gs6xapi.kurdmap.eu {
	import kurdmap_security_headers
	import kurdmap_compression
	import kurdmap_json_log_api

	# JSON API does not require a document CSP header.
	header -Content-Security-Policy

	request_body {
		max_size 10MB
	}

	reverse_proxy {$KURDMAP_API_UPSTREAM:localhost:8080} {
		import kurdmap_proxy_headers
		# Override Host to "localhost" so ASP.NET AllowedHosts passes.
		# The real client domain is still available via X-Forwarded-Host (set by Caddy).
		header_up Host "localhost"
		health_uri /health
		health_interval 30s
		transport http {
			dial_timeout 5s
			response_header_timeout 30s
		}
	}
}
