# ╔══════════════════════════════════════════════════╗
# ║         KurdMap Environment Variables            ║
# ║  Copy to .env and fill in production values      ║
# ╚══════════════════════════════════════════════════╝

# === General ===
ENVIRONMENT=Production
APP_NAME=KurdMap

# === GHCR (Container Registry) ===
GHCR_USERNAME=your-github-username-lowercase

# === PostgreSQL ===
POSTGRES_HOST=postgres
POSTGRES_PORT=55432
POSTGRES_DB=kurdmap
POSTGRES_USER=kurdmap_user
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=56379
REDIS_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# === JWT ===
JWT_SECRET=CHANGE_ME_USE_64_CHAR_RANDOM_STRING_openssl_rand_base64_48
JWT_ISSUER=https://gs6xapi.kurdmap.eu
JWT_AUDIENCE=https://kurdmap.de
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# === Connection Strings (used by API) ===
ConnectionStrings__DefaultConnection=Host=${POSTGRES_HOST};Port=${POSTGRES_PORT};Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}
ConnectionStrings__Redis=${REDIS_HOST}:${REDIS_PORT},password=${REDIS_PASSWORD}

# === CORS ===
Cors__AllowedOrigins__0=https://kurdmap.de
Cors__AllowedOrigins__1=https://admin.kurdmap.de

# === API ===
API_URL=https://gs6xapi.kurdmap.eu
API_PORT=8080

# === Admin Panel ===
ADMIN_URL=https://admin.kurdmap.de
# Loopback port the host Caddy reverse-proxies to (must match the Caddyfile).
ADMIN_PORT=4001

# === Frontend SSR ===
FRONTEND_URL=https://kurdmap.de
FRONTEND_PORT=4000

# === SMTP (Email) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@kurdmap.de
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@kurdmap.de

# === Logging ===
Serilog__MinimumLevel__Default=Warning
SEQ_URL=

# === Seed ===
SEED_ADMIN_EMAIL=admin@kurdmap.de
SEED_ADMIN_PASSWORD=sgsgHGgg5%%6g556GFgfgfFFGffgh-itt/8
